{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist-test",
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "tests/**/*.ts",
    "test/**/*.ts",
    "src/archivist/testing/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "dist-test"]
}
